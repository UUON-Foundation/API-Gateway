# UUON Gateway — Environment Variables
# Copy this to .env and fill in your values

# Required — set a strong random string
ADMIN_TOKEN=your_admin_token_here

# Optional — Resend email (for waitlist confirmations)
RESEND_API_KEY=re_placeholder
SENDER_EMAIL=onboarding@uuon.world
OWNER_EMAIL=your@email.com

# Frontend → Backend URL
# Local:      http://localhost:8001
# Production: https://your-backend.up.railway.app
REACT_APP_BACKEND_URL=http://localhost:8001

# Optional — restrict CORS origins (comma-separated)
# CORS_ORIGINS=https://uuon.world,https://gateway.uuon.world
CORS_ORIGINS=*
